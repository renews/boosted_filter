#-------------------------------------------------------------------------------
# Subsection: [ZZ.1] - Items that drop on rare events and some fallbacks.
#-------------------------------------------------------------------------------
# Oddball items & items that should never normally drop
Show
	Class = "Quest"
	SetTextColor 62 101 163 255 # Quest Items
	SetBackgroundColor 165 194 233 240 # Quest Items
	SetBorderColor 77 121 178 255 # Quest Items
	SetFontSize 45
	PlayAlertSound 16 250 # Quest Items
	MinimapIcon 0 Blue Pentagon
	PlayEffect Blue
Show
	BaseType = "Avian Slippers" "Sacrificial Garb" "Ruby Amulet"
	SetBackgroundColor 100 66 0 240
	SetBorderColor 0 255 255 255
	SetFontSize 42
Show
	BaseType = "Jet Amulet" "Jet Ring" "Golden Obi" "Golden Mantle" "Golden Bracers" "Golden Caligae" "Golden Hoop" "Golden Wreath" "Golden Flame"
	SetBackgroundColor 100 66 0 240
	SetBorderColor 0 255 255 255
	SetFontSize 42
Show
	Sockets = "WWW"
	Class = "Wand" "Sceptre" "Dagger" "Claw" "One Hand" "Shield"
	SetTextColor 0 0 0 255
	SetBackgroundColor 43 32 23 240 # item_t1
	SetBorderColor 169 169 254 255 # Items - Weapons
