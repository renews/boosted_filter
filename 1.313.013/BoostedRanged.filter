	HasInfluence = "None"
	FracturedItem = False
	Corrupted = False
	Mirrored = False
	Sockets < "6"
	Rarity = Normal
	ItemLevel >= 69
	AreaLevel < 77
	BaseType "Occultist's Vestment" "Glorious Plate" "Sorcerer Boots"
